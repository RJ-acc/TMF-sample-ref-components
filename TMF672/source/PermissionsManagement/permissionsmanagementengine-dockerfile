FROM python:3.12-slim

WORKDIR /app

COPY source/PermissionsManagement/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt

COPY source/PermissionsManagement /app

ENV PYTHONPATH=/app

CMD ["uvicorn", "permissionsManagementEngineMicroservice.implementation.app:app", "--host", "0.0.0.0", "--port", "8081"]
