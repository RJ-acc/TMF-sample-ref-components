FROM python:3.12-slim

WORKDIR /app

COPY source/TroubleTicketManagement/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt

COPY source/TroubleTicketManagement /app

ENV PYTHONPATH=/app

CMD ["uvicorn", "partyRoleMicroservice.implementation.app:app", "--host", "0.0.0.0", "--port", "8080"]
