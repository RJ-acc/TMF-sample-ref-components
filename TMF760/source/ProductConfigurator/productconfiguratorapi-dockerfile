FROM python:3.12-slim

WORKDIR /app

COPY source/ProductConfigurator/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt

COPY source/ProductConfigurator /app

ENV PYTHONPATH=/app

CMD ["uvicorn", "productConfigurationMicroservice.implementation.app:app", "--host", "0.0.0.0", "--port", "8080"]
